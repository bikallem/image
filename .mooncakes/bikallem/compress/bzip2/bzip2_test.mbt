///|
test "bzip2 decompress empty" {
  let compressed : Bytes = [
    0x42, 0x5A, 0x68, 0x39, 0x17, 0x72, 0x45, 0x38, 0x50, 0x90, 0x00, 0x00, 0x00,
    0x00,
  ]
  let result = @bzip2.decompress(compressed)
  assert_eq(result, b"")
}

///|
test "bzip2 decompress Hello" {
  let compressed : Bytes = [
    0x42, 0x5A, 0x68, 0x39, 0x31, 0x41, 0x59, 0x26, 0x53, 0x59, 0x1A, 0x54, 0x64,
    0x92, 0x00, 0x00, 0x00, 0x05, 0x00, 0x00, 0x40, 0x02, 0x04, 0xA0, 0x00, 0x21,
    0x9A, 0x68, 0x33, 0x4D, 0x13, 0x33, 0x8B, 0xB9, 0x22, 0x9C, 0x28, 0x48, 0x0D,
    0x2A, 0x32, 0x49, 0x00,
  ]
  let result = @bzip2.decompress(compressed)
  assert_eq(result, b"Hello")
}

///|
test "bzip2 decompress repeated" {
  let compressed : Bytes = [
    0x42, 0x5A, 0x68, 0x39, 0x31, 0x41, 0x59, 0x26, 0x53, 0x59, 0xA2, 0xF8, 0x4F,
    0x0E, 0x00, 0x00, 0x02, 0x44, 0x00, 0x01, 0x00, 0x20, 0x00, 0x20, 0x00, 0x21,
    0x00, 0x82, 0x0B, 0x17, 0x72, 0x45, 0x38, 0x50, 0x90, 0xA2, 0xF8, 0x4F, 0x0E,
  ]
  let result = @bzip2.decompress(compressed)
  assert_eq(result, b"AAAAAAAAAA")
}

///|
test "bzip2 decompress abcabc" {
  let compressed : Bytes = [
    0x42, 0x5A, 0x68, 0x39, 0x31, 0x41, 0x59, 0x26, 0x53, 0x59, 0x9F, 0x5D, 0xC7,
    0xE9, 0x00, 0x00, 0x01, 0x81, 0x00, 0x38, 0x00, 0x20, 0x00, 0x30, 0xCC, 0x05,
    0x41, 0x8A, 0x63, 0x8B, 0xB9, 0x22, 0x9C, 0x28, 0x48, 0x4F, 0xAE, 0xE3, 0xF4,
    0x80,
  ]
  let result = @bzip2.decompress(compressed)
  assert_eq(result, b"abcabcabcabc")
}

///|
test "bzip2 invalid magic" {
  let data : Bytes = [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]
  let result = try? @bzip2.decompress(data)
  guard result is Err(_) else { fail("expected error for invalid magic") }
}

///|
test "bzip2 decompress larger text" {
  let compressed : Bytes = [
    0x42, 0x5A, 0x68, 0x39, 0x31, 0x41, 0x59, 0x26, 0x53, 0x59, 0x48, 0x73, 0xE0,
    0xDC, 0x00, 0x00, 0x36, 0x93, 0x80, 0x40, 0x01, 0x04, 0x00, 0x3F, 0xFF, 0xFF,
    0xF0, 0x20, 0x00, 0x90, 0x28, 0x00, 0x1A, 0x00, 0x00, 0x0A, 0x54, 0xA6, 0xA6,
    0x9A, 0x34, 0x61, 0x34, 0x36, 0xA6, 0xDA, 0x93, 0x09, 0xC9, 0x32, 0x9F, 0x49,
    0x94, 0xF8, 0x4D, 0x53, 0x09, 0xAA, 0x74, 0x4F, 0x74, 0xFB, 0x4C, 0x27, 0x64,
    0xC2, 0x76, 0x26, 0xC9, 0xB9, 0x3B, 0xA7, 0x84, 0xEA, 0x9B, 0x27, 0xA2, 0x7E,
    0x26, 0x13, 0x72, 0x65, 0x3B, 0xA6, 0x89, 0xC9, 0x35, 0x4F, 0x09, 0xA2, 0x75,
    0x4F, 0xE4, 0xD9, 0x34, 0x4C, 0xA6, 0x53, 0xA2, 0xAF, 0x29, 0xE5, 0x3F, 0xC5,
    0xDC, 0x91, 0x4E, 0x14, 0x24, 0x12, 0x1C, 0xF8, 0x37, 0x00,
  ]
  let result = @bzip2.decompress(compressed)
  // Should be "The quick brown fox jumps over the lazy dog. " repeated 10 times
  assert_eq(result.length(), 450)
  // Check first few bytes
  assert_eq(result[0], b'T')
  assert_eq(result[1], b'h')
  assert_eq(result[2], b'e')
}

///|
test "bzip2 truncated data" {
  let data : Bytes = [0x42, 0x5A, 0x68, 0x39]
  let result = try? @bzip2.decompress(data)
  guard result is Err(_) else { fail("expected error for truncated data") }
}

///|
test "bzip2 wrong block level" {
  // Valid magic "BZ" but invalid block level (level '0' = 0x30)
  let data : Bytes = [0x42, 0x5A, 0x68, 0x30, 0x00, 0x00, 0x00, 0x00]
  let result = try? @bzip2.decompress(data)
  guard result is Err(_) else { fail("expected error for invalid block level") }
}

///|
test "bzip2 corrupt block magic" {
  // Valid header but corrupt block magic
  let data : Bytes = [
    0x42, 0x5A, 0x68, 0x39, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  ]
  let result = try? @bzip2.decompress(data)
  guard result is Err(_) else { fail("expected error for corrupt block magic") }
}

///|
test "bzip2 round-trip Hello" {
  let original : Bytes = b"Hello"
  let compressed = @bzip2.compress(original)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}

///|
test "bzip2 round-trip repeated" {
  let original : Bytes = b"AAAAAAAAAA"
  let compressed = @bzip2.compress(original)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}

///|
test "bzip2 round-trip abcabc" {
  let original : Bytes = b"abcabcabcabc"
  let compressed = @bzip2.compress(original)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}

///|
test "bzip2 round-trip empty" {
  let original : Bytes = b""
  let compressed = @bzip2.compress(original)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}

///|
test "bzip2 round-trip larger" {
  let sb = @buffer.new(size_hint=500)
  for _ in 0..<10 {
    sb.write_bytes(b"The quick brown fox jumps over the lazy dog. ")
  }
  let original = sb.to_bytes()
  let compressed = @bzip2.compress(original)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}

///|
test "bzip2 round-trip binary data" {
  let original = Bytes::makei(256, fn(i) { i.to_byte() })
  let compressed = @bzip2.compress(original)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}

///|
test "bzip2 round-trip level 1" {
  let original : Bytes = b"Hello, bzip2 compression at level 1!"
  let compressed = @bzip2.compress(original, level=1)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}

///|
test "bzip2 round-trip RLE1 trigger" {
  // 10 copies of the same byte should trigger RLE1 encoding
  let sb = @buffer.new(size_hint=100)
  for _ in 0..<10 {
    sb.write_byte(b'X')
  }
  sb.write_bytes(b"abc")
  let original = sb.to_bytes()
  let compressed = @bzip2.compress(original)
  let decompressed = @bzip2.decompress(compressed)
  assert_eq(decompressed, original)
}
